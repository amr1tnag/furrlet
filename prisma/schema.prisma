generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  password   String
  name       String
  role       String
  phone      String?
  isVerified Boolean   @default(false)
  otpHash    String?
  otpExpiry  DateTime?
  createdAt  DateTime  @default(now())

  walkerProfile     WalkerProfile?
  dogs              Dog[]
  bookingsAsOwner   Booking[]          @relation("OwnerBookings")
  bookingsAsWalker  Booking[]          @relation("WalkerBookings")
  sentMessages      Message[]          @relation("SentMessages")
  pushSubscriptions PushSubscription[]
}

model WalkerProfile {
  id                 String  @id @default(cuid())
  userId             String  @unique
  user               User    @relation(fields: [userId], references: [id])
  bio                String
  hourlyRate         Float
  city               String
  availability       String
  rating             Float   @default(0)
  reviewCount        Int     @default(0)
  photoUrl           String  @default("")
  verified           Boolean @default(false)
  verificationStatus String  @default("NONE")
  isActive           Boolean @default(true)
  aadhaarNumber      String  @default("")
  upiId              String  @default("")
}

model Dog {
  id       String @id @default(cuid())
  ownerId  String
  owner    User   @relation(fields: [ownerId], references: [id])
  name     String
  breed    String
  size     String
  notes    String @default("")
  bookings Booking[]
}

model Booking {
  id            String   @id @default(cuid())
  walkerId      String
  walker        User     @relation("WalkerBookings", fields: [walkerId], references: [id])
  dogId         String
  dog           Dog      @relation(fields: [dogId], references: [id])
  ownerId       String
  owner         User     @relation("OwnerBookings", fields: [ownerId], references: [id])
  status        String   @default("PENDING")
  date          String
  duration      Int
  totalPrice    Float
  paymentId     String   @default("")
  paymentStatus String   @default("UNPAID")
  address       String   @default("")
  createdAt     DateTime @default(now())
  trackingActive Boolean   @default(false)
  walkStartedAt  DateTime?
  lat           Float?
  lng           Float?
  startOtp      String?
  endOtp        String?
  review        Review?
  messages      Message[]
}

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  walkerId  String
  ownerId   String
  rating    Int
  comment   String   @default("")
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])
  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  body      String
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
